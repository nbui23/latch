{
  "manifest_version": 3,
  "name": "Latch",
  "version": "1.0.0",
  "description": "Focus blocker — shows a clean blocked page when a site is blocked by the Latch desktop app.",
  "permissions": [
    "storage",
    "tabs",
    "webNavigation",
    "alarms",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "nativeMessaging"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Latch"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "blocked.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
